name: morning-brief
steps:
  - id: clean_temp
    run: |
      rm -rf /home/node/.openclaw/workspace/data/morning_brief
      mkdir -p /home/node/.openclaw/workspace/data/morning_brief

  - id: fetch_withings
    run: python3 /home/node/.openclaw/workspace/skills/withings-family/scripts/withings.py stephen sleep 0 --json-only > "/home/node/.openclaw/workspace/data/morning_brief/sleep.json"

  - id: summarize_sleep
    run: |
      /opt/custom-tools/llm_invoke_json '{"payloadFile": "morning_brief/sleep.json", "promptFile": "sleep_summary",  "model": "openrouter/meta-llama/llama-3.3-70b-instruct", "temperature": 0.1}' > '/home/node/.openclaw/workspace/data/morning_brief/final_sleep.json'

  - id: fetch_inoreader
    run: /home/node/.openclaw/workspace/skills/inoreader/inoreader.sh "stream/contents/user/-/state/com.google/reading-list?n=20" > "/home/node/.openclaw/workspace/data/morning_brief/inoreader.json"

  - id: analyze_social
    run: |
      /opt/custom-tools/llm_invoke_json '{"payloadFile": "morning_brief/inoreader.json", "promptFile": "social_media_summary", "model": "openrouter/meta-llama/llama-3.3-70b-instruct", "temperature": 0.1}' > "/home/node/.openclaw/workspace/data/morning_brief/final_social.json"

  - id: combine_data
    run: |
      jq -n \
        --slurpfile sleep /home/node/.openclaw/workspace/data/morning_brief/final_sleep.json \
        --slurpfile social /home/node/.openclaw/workspace/data/morning_brief/final_social.json \
        '{sleep: $sleep[0], social: $social[0]}' > "/home/node/.openclaw/workspace/data/morning_brief/brief_combined.json"

  - id: format_brief
    run: |
      /opt/custom-tools/llm_invoke_json '{"payloadFile": "morning_brief/brief_combined.json", "promptFile": "morning_brief_formatter", "model": "openrouter/meta-llama/llama-3.3-70b-instruct", "temperature": 0.1}' > "/home/node/.openclaw/workspace/data/morning_brief/format_brief_output.json"
      cat "/home/node/.openclaw/workspace/data/morning_brief/format_brief_output.json"

  - id: send_to_signal
    run: |
      CONTENT=$(cat "/home/node/.openclaw/workspace/data/morning_brief/format_brief_output.json" | jq -r '.details.json.response // .json.response // .response // empty')
      if [ -n "$CONTENT" ] && [ "$CONTENT" != "null" ]; then
        /opt/custom-tools/message_invoke "signal:+447738375172" "$CONTENT"
      fi

  - id: output
    run: cat
    stdin: |
      $format_brief.stdout
