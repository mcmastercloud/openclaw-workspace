      "allowedOrigins": [
        "http://192.168.30.3:18789",
        "http://192.168.30.15:18789",
        "https://openclaw.mcmaster.cloud",
        "https://openclaw.mcmaster.cloud:18789"
      ],
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true
    }
  },
  "logging": {
    "file": "~/.openclaw/logs/gateway.log",
    "level": "warn",
    "consoleLevel": "warn",
    "consoleStyle": "pretty"
