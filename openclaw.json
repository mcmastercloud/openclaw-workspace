          {
            "id": "gemma3:4b",
            "name": "Gemma 3 4b (HPC)",
            "reasoning": false,
            "input": [
              "text"
            ],
            "contextWindow": 64000,
            "maxTokens": 4096,
            "params": {
              "num_ctx": 64000
            }
          }
        ]
      },
      "openai": {
        "baseUrl": "https://api.openai.com/v1",
