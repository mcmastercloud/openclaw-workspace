            "maxTokens": 4096
          },
          {
            "id": "text-embedding-3-small",
            "name": "Text Embedding 3 Small",
            "contextWindow": 8192
          }
        ]
      },
      "openrouter": {
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKey": "${OPENROUTER_API_KEY}",
        "models": [
          {
            "id": "google/gemini-3.1-pro-preview",
